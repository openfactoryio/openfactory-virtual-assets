{
  "name": "OpenFactory-VirtualAssets — Collection of virtual assets for OpenFactory",
  "image": "ghcr.io/openfactoryio/devcontainer-py3.12",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {},
    "ghcr.io/openfactoryio/openfactory-sdk/infra": {},
    "ghcr.io/openfactoryio/openfactory-sdk/opcua-connector": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "Traefik",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "OPENFACTORY_ENV": "dev",
    "OPENFACTORY_UNS_SCHEMA": "/workspaces/openfactory-virtual-assets/.devcontainer/uns.yml"
  },
  "postCreateCommand": "pip install -e .[dev]"
}
